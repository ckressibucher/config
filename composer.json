{
    "name": "ckr/config",
    "description": "Simple access to multi dimensional arrays, useful for configuration data",
    "require": {
        "php": ">=7.1",
        "ckr/arraymerger": "^2.0.0"
    },
    "require-dev": {
        "phpspec/phpspec": "~8.2",
        "phpunit/phpunit": "^8.5"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Claudio Kressibucher",
            "email": "ckressibucher@graphicworks.ch"
        }
    ],
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Ckr\\Config\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "spec\\Ckr\\Config\\": "spec/"
        }
    }
}
